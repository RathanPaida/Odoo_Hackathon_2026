# Prisma / Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/oodoprep?schema=public"

# Auth secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"

# Auth token config
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="OodoPrep"

# Email (Resend or SMTP). Set EMAIL_PROVIDER to "resend" or "smtp".
EMAIL_PROVIDER="smtp"
EMAIL_FROM="OodoPrep <noreply@example.com>"

# SMTP (used when EMAIL_PROVIDER=smtp)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# Resend (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=""

# Rate limiting
RATE_LIMIT_MAX="5"
RATE_LIMIT_WINDOW_MS="60000"
